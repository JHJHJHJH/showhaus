# Environment (development, production)
NODE_ENV=development

# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL/PostGIS)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=showhouse_db

# Martin Vector Tile Server
MARTIN_BASE_URL=http://localhost:3333
MARTIN_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5433/showhouse_db

# External APIs
URA_API_KEY=your_ura_api_key

# Authentication (Google OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application URLs
SHOWHOUSE_API_URL_DEV=http://localhost:8080
SHOWHOUSE_URL_DEV=http://localhost:3210
SHOWHOUSE_API_URL_PROD=
SHOWHOUSE_URL_PROD=
