# Environment (development, production)
NODE_ENV=development

# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL/PostGIS)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_for_local_dev
POSTGRES_DB=showhouse_db

# Martin Vector Tile Server
MARTIN_BASE_URL=http://localhost:3333
# For docker compose, use postgres_db:5432. For local host access, use localhost:5433.
MARTIN_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres_db:5432/${POSTGRES_DB}

# External APIs
URA_API_KEY=your_ura_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# NewLauncher scraper
NEWLAUNCHER_DATA_DIR=
NEWLAUNCHER_DOWNLOAD_ASSETS=true

# Authentication (Google OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application URLs
SHOWHOUSE_API_URL_DEV=http://localhost:8080
SHOWHOUSE_URL_DEV=http://localhost:3210
SHOWHOUSE_API_URL_PROD=
SHOWHOUSE_URL_PROD=
